<html>
<head>
<HTA:APPLICATION
  ID="PomodoroTimer"
  APPLICATIONNAME="番茄钟 / Pomodoro"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  BORDER="thin"
  INNERBORDER="no"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  MINIMIZEBUTTON="yes"
  MAXIMIZEBUTTON="no"
/>
<title>番茄钟</title>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=11">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Microsoft YaHei UI','Microsoft YaHei',Arial,sans-serif;
  background: #f6f4f0;
  color: #0e0e0e;
  overflow: hidden;
  -ms-user-select: none;
  user-select: none;
}

#app {
  width: 400px;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-direction: column;
  flex-direction: column;
  -ms-flex-align: center;
  align-items: center;
  border-top: 3px solid #0e0e0e;
}

/* ── header row ── */
.hdr-row {
  width: 100%;
  position: relative;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-pack: center;
  justify-content: center;
  -ms-flex-align: center;
  align-items: center;
  padding: 13px 16px;
  border-bottom: 1px solid #0e0e0e;
}
.hdr {
  font-size: 10px;
  font-weight: 900;
  color: #0e0e0e;
  letter-spacing: 6px;
  text-transform: uppercase;
}
.lang-btn {
  position: absolute;
  right: 16px;
  padding: 3px 9px;
  border-radius: 0;
  border: 1px solid #0e0e0e;
  background: transparent;
  color: #0e0e0e;
  cursor: pointer;
  font-size: 9px;
  font-weight: 700;
  font-family: inherit;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  -webkit-transition: background 0.12s, color 0.12s;
  transition: background 0.12s, color 0.12s;
}
.lang-btn:hover { background: #0e0e0e; color: #f6f4f0; }

/* ── mode tabs ── */
.tabs {
  display: -ms-flexbox;
  display: flex;
  width: 356px;
  border-bottom: 1px solid #ccc;
  margin: 12px 0 8px;
}
.tab {
  padding: 7px 16px 8px;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  background: transparent;
  color: #aaa;
  font-family: inherit;
  font-size: 10px;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  -webkit-transition: color 0.12s;
  transition: color 0.12s;
}
.tab.on { color: #c0281e; border-bottom-color: #c0281e; }
.tab:hover { color: #444; }

/* ── ring timer ── */
.ring-wrap {
  position: relative;
  width: 228px;
  height: 228px;
  margin: 6px 0 8px;
}
.ring-svg {
  width: 228px; height: 228px;
  display: block;
  -ms-transform: rotate(-90deg);
  transform: rotate(-90deg);
}
.r-tick-sm { fill:none; stroke:#dedad5; stroke-width:1;   stroke-dasharray: 1.5 9.29; }
.r-tick-lg { fill:none; stroke:#b8b3ac; stroke-width:2.5; stroke-dasharray: 3   50.93; }
.r-bg { fill:none; stroke:#e2ddd7; stroke-width:5; }
.r-fg {
  fill: none;
  stroke: #c0281e;
  stroke-width: 5;
  stroke-linecap: butt;
  -webkit-transition: stroke-dashoffset 0.9s linear, stroke 0.4s;
  transition: stroke-dashoffset 0.9s linear, stroke 0.4s;
}
.ring-center {
  position: absolute;
  top:0; left:0; right:0; bottom:0;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-direction: column;
  flex-direction: column;
  -ms-flex-pack: center;
  justify-content: center;
  -ms-flex-align: center;
  align-items: center;
}
.digits {
  font-size: 60px;
  font-weight: 700;
  font-family: 'Courier New',Courier,monospace;
  letter-spacing: -1px;
  line-height: 1;
  color: #0e0e0e;
}
.mode-label {
  font-size: 8px;
  color: #aaa;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-top: 9px;
}

/* ── pomodoro dots ── */
.dots {
  display: -ms-flexbox;
  display: flex;
  gap: 10px;
  margin: 2px 0 4px;
}
.dot {
  width: 6px; height: 6px;
  background: #d8d3cc;
}
.dot.on { background: #c0281e; }
.status-txt {
  font-size: 9px;
  color: #aaa;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 14px;
}

/* ── controls ── */
.ctrl {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-align: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.ico-btn {
  width: 40px; height: 40px;
  border-radius: 0;
  border: 1px solid #bbb;
  background: transparent;
  color: #777;
  cursor: pointer;
  font-size: 16px;
  font-family: inherit;
  line-height: 38px;
  text-align: center;
  -webkit-transition: border-color 0.12s, color 0.12s, background 0.12s;
  transition: border-color 0.12s, color 0.12s, background 0.12s;
}
.ico-btn:hover { border-color: #0e0e0e; color: #0e0e0e; background: #eceae6; }
.go-btn {
  width: 134px; height: 40px;
  border-radius: 0;
  border: 2px solid #0e0e0e;
  background: #0e0e0e;
  color: #f6f4f0;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 4px;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
  -webkit-transition: background 0.12s, border-color 0.12s;
  transition: background 0.12s, border-color 0.12s;
}
.go-btn:hover { background: #c0281e; border-color: #c0281e; }

/* ── settings ── */
.cfg {
  display: -ms-flexbox;
  display: flex;
  width: 356px;
  border: 1px solid #ccc;
  border-top: 2px solid #0e0e0e;
}
.cfg-col {
  -ms-flex: 1; flex: 1;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-direction: column;
  flex-direction: column;
  -ms-flex-align: center;
  align-items: center;
  padding: 11px 4px;
  border-right: 1px solid #e2ddd7;
}
.cfg-col:last-child { border-right: none; }
.cfg-name {
  font-size: 8px;
  color: #aaa;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 7px;
  text-align: center;
}
.cfg-row {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-align: center;
  align-items: center;
  gap: 8px;
}
.adj-btn {
  width: 18px; height: 18px;
  border-radius: 0;
  border: 1px solid #bbb;
  background: transparent;
  color: #777;
  cursor: pointer;
  font-size: 13px;
  font-family: inherit;
  text-align: center;
  line-height: 16px;
  -webkit-transition: border-color 0.1s, color 0.1s;
  transition: border-color 0.1s, color 0.1s;
}
.adj-btn:hover { border-color: #0e0e0e; color: #0e0e0e; }
.adj-val {
  font-size: 16px;
  font-weight: 700;
  font-family: 'Courier New',Courier,monospace;
  min-width: 22px;
  text-align: center;
  color: #0e0e0e;
}

/* ── footer ── */
.ftr {
  font-size: 9px;
  color: #bbb;
  letter-spacing: 2px;
  text-transform: uppercase;
  width: 356px;
  text-align: center;
  padding-top: 10px;
  margin: 4px 0 14px;
  border-top: 1px solid #e2ddd7;
}
</style>
</head>
<body>
<div id="app">

  <div class="hdr-row">
    <div class="hdr" id="hdrTitle">&#127813; 番茄钟</div>
    <button class="lang-btn" id="langBtn" onclick="toggleLang()">EN</button>
  </div>

  <div class="tabs">
    <button class="tab on" id="tw" onclick="switchMode('work')">专注</button>
    <button class="tab"    id="ts" onclick="switchMode('shortBreak')">短休息</button>
    <button class="tab"    id="tl" onclick="switchMode('longBreak')">长休息</button>
  </div>

  <div class="ring-wrap">
    <svg class="ring-svg" viewBox="0 0 228 228">
      <circle class="r-tick-sm" cx="114" cy="114" r="103"/>
      <circle class="r-tick-lg" cx="114" cy="114" r="103"/>
      <circle class="r-bg" cx="114" cy="114" r="93"/>
      <circle class="r-fg" id="ring" cx="114" cy="114" r="93"
              stroke-dasharray="584.34" stroke-dashoffset="0"/>
    </svg>
    <div class="ring-center">
      <div class="digits"     id="digits">25:00</div>
      <div class="mode-label" id="modeLabel">工作时间</div>
    </div>
  </div>

  <div class="dots">
    <div class="dot" id="d0"></div>
    <div class="dot" id="d1"></div>
    <div class="dot" id="d2"></div>
    <div class="dot" id="d3"></div>
  </div>
  <div class="status-txt" id="statusTxt">第 1 / 4 个番茄</div>

  <div class="ctrl">
    <button class="ico-btn" id="resetBtn" onclick="resetTimer()" title="重置">&#8635;</button>
    <button class="go-btn"  id="goBtn"    onclick="toggleTimer()">开始</button>
    <button class="ico-btn" id="skipBtn"  onclick="skipSession()" title="跳过">&#9197;</button>
  </div>

  <div class="cfg">
    <div class="cfg-col">
      <div class="cfg-name" id="cfgNameWork">专注 (分钟)</div>
      <div class="cfg-row">
        <button class="adj-btn" onclick="adjustSetting('work',-1)">-</button>
        <span class="adj-val" id="cfgWork">25</span>
        <button class="adj-btn" onclick="adjustSetting('work',1)">+</button>
      </div>
    </div>
    <div class="cfg-col">
      <div class="cfg-name" id="cfgNameShort">短休息 (分钟)</div>
      <div class="cfg-row">
        <button class="adj-btn" onclick="adjustSetting('short',-1)">-</button>
        <span class="adj-val" id="cfgShort">5</span>
        <button class="adj-btn" onclick="adjustSetting('short',1)">+</button>
      </div>
    </div>
    <div class="cfg-col">
      <div class="cfg-name" id="cfgNameLong">长休息 (分钟)</div>
      <div class="cfg-row">
        <button class="adj-btn" onclick="adjustSetting('long',-1)">-</button>
        <span class="adj-val" id="cfgLong">15</span>
        <button class="adj-btn" onclick="adjustSetting('long',1)">+</button>
      </div>
    </div>
  </div>

  <div class="ftr" id="footer">今日完成: 0 个番茄</div>

</div>

<script language="JavaScript">
var CIRC = 584.34; // 2 * PI * 93

// ── i18n strings ──────────────────────────────────────────────────────────────
var strings = {
  zh: {
    appTitle:    '番茄钟',
    hdr:         '&#127813; 番茄钟',
    langBtn:     'EN',
    tabWork:     '专注',
    tabShort:    '短休息',
    tabLong:     '长休息',
    modeWork:    '工作时间',
    modeShort:   '短暂休息',
    modeLong:    '长时休息',
    statusWork:  function(n) { return '第 ' + n + ' / 4 个番茄'; },
    statusShort: '休息一下，喝杯茶 ☕',
    statusLong:  '好好休息，充充电 ★',
    footer:      function(n) { return '今日完成: ' + n + ' 个番茄'; },
    start:       '开始',
    pause:       '暂停',
    resume:      '继续',
    reset:       '重置',
    skip:        '跳过',
    cfgWork:     '专注 (分钟)',
    cfgShort:    '短休息 (分钟)',
    cfgLong:     '长休息 (分钟)'
  },
  en: {
    appTitle:    'Pomodoro',
    hdr:         '&#127813; Pomodoro',
    langBtn:     '中文',
    tabWork:     'Focus',
    tabShort:    'Short Break',
    tabLong:     'Long Break',
    modeWork:    'Focus Time',
    modeShort:   'Short Break',
    modeLong:    'Long Break',
    statusWork:  function(n) { return 'Pomodoro ' + n + ' of 4'; },
    statusShort: 'Take a break, have some tea ☕',
    statusLong:  'Rest well, recharge ★',
    footer:      function(n) { return 'Today: ' + n + ' pomodoro' + (n !== 1 ? 's' : '') + ' done'; },
    start:       'Start',
    pause:       'Pause',
    resume:      'Resume',
    reset:       'Reset',
    skip:        'Skip',
    cfgWork:     'Focus (min)',
    cfgShort:    'Short (min)',
    cfgLong:     'Long (min)'
  }
};

// ── state ─────────────────────────────────────────────────────────────────────
var lang        = 'zh';
var settings    = { work: 25, short: 5, long: 15 };
var currentMode = 'work';
var isRunning   = false;
var timeLeft    = 25 * 60;
var totalSec    = 25 * 60;
var ticker      = null;
var cyclePos    = 0;
var totalDone   = 0;

var modeStroke = {
  work:       '#c0281e',
  shortBreak: '#1e6b5e',
  longBreak:  '#1e4d7a'
};

// ── helpers ───────────────────────────────────────────────────────────────────
function pad(n) { return (n < 10 ? '0' : '') + n; }
function T()    { return strings[lang]; }

function goBtnText() {
  if (isRunning)               return T().pause;
  if (timeLeft < totalSec)     return T().resume;
  return T().start;
}

// ── render ────────────────────────────────────────────────────────────────────
function render() {
  var m  = Math.floor(timeLeft / 60);
  var s  = timeLeft % 60;
  var ts = pad(m) + ':' + pad(s);

  document.getElementById('digits').innerHTML = ts;
  document.title = ts + ' - ' + T().appTitle;

  var ratio  = totalSec > 0 ? timeLeft / totalSec : 0;
  var ring   = document.getElementById('ring');
  ring.style.strokeDashoffset = CIRC * (1 - ratio);
  ring.style.stroke = modeStroke[currentMode];

  var modeKey = currentMode === 'work' ? 'modeWork'
              : currentMode === 'shortBreak' ? 'modeShort' : 'modeLong';
  document.getElementById('modeLabel').innerHTML = T()[modeKey];

  var st = currentMode === 'work'       ? T().statusWork(cyclePos + 1)
         : currentMode === 'shortBreak' ? T().statusShort
         : T().statusLong;
  document.getElementById('statusTxt').innerHTML = st;
  document.getElementById('footer').innerHTML = T().footer(totalDone);
}

// Refresh all static labels (tabs, buttons, cfg names) for current language.
function renderLang() {
  document.getElementById('hdrTitle').innerHTML     = T().hdr;
  document.getElementById('langBtn').innerHTML      = T().langBtn;
  document.getElementById('tw').innerHTML           = T().tabWork;
  document.getElementById('ts').innerHTML           = T().tabShort;
  document.getElementById('tl').innerHTML           = T().tabLong;
  document.getElementById('resetBtn').title         = T().reset;
  document.getElementById('skipBtn').title          = T().skip;
  document.getElementById('cfgNameWork').innerHTML  = T().cfgWork;
  document.getElementById('cfgNameShort').innerHTML = T().cfgShort;
  document.getElementById('cfgNameLong').innerHTML  = T().cfgLong;
  document.getElementById('goBtn').innerHTML        = goBtnText();
  render();
}

function renderDots() {
  for (var i = 0; i < 4; i++) {
    document.getElementById('d' + i).className = 'dot' + (i < cyclePos ? ' on' : '');
  }
}

// ── language toggle ───────────────────────────────────────────────────────────
function toggleLang() {
  lang = (lang === 'zh') ? 'en' : 'zh';
  renderLang();
}

// ── timer controls ────────────────────────────────────────────────────────────
function toggleTimer() {
  if (isRunning) {
    stopTicker();
    document.getElementById('goBtn').innerHTML = T().resume;
  } else {
    isRunning = true;
    document.getElementById('goBtn').innerHTML = T().pause;
    ticker = setInterval(tick, 1000);
  }
}

function tick() {
  if (timeLeft > 0) {
    timeLeft--;
    render();
  }
  if (timeLeft <= 0) {
    onComplete();
  }
}

function stopTicker() {
  isRunning = false;
  if (ticker) { clearInterval(ticker); ticker = null; }
}

function resetTimer() {
  stopTicker();
  timeLeft = totalSec;
  document.getElementById('goBtn').innerHTML = T().start;
  render();
}

function skipSession() {
  stopTicker();
  document.getElementById('goBtn').innerHTML = T().start;
  if (currentMode === 'work') onComplete();
  else applyMode('work');
}

function onComplete() {
  stopTicker();
  document.getElementById('goBtn').innerHTML = T().start;
  playSound();

  if (currentMode === 'work') {
    totalDone++;
    cyclePos++;
    renderDots();
    if (cyclePos >= 4) {
      cyclePos = 0;
      renderDots();
      applyMode('longBreak');
    } else {
      applyMode('shortBreak');
    }
  } else {
    applyMode('work');
  }
}

function applyMode(mode) {
  currentMode = mode;
  document.getElementById('tw').className = 'tab' + (mode === 'work'       ? ' on' : '');
  document.getElementById('ts').className = 'tab' + (mode === 'shortBreak' ? ' on' : '');
  document.getElementById('tl').className = 'tab' + (mode === 'longBreak'  ? ' on' : '');

  var mins = (mode === 'work') ? settings.work
           : (mode === 'shortBreak') ? settings.short
           : settings.long;
  totalSec = mins * 60;
  timeLeft  = totalSec;
  render();
}

function switchMode(mode) {
  stopTicker();
  document.getElementById('goBtn').innerHTML = T().start;
  applyMode(mode);
}

// ── settings ──────────────────────────────────────────────────────────────────
function adjustSetting(type, delta) {
  if (isRunning) return;
  if (type === 'work') {
    settings.work = Math.max(1, Math.min(60, settings.work + delta));
    document.getElementById('cfgWork').innerHTML = settings.work;
    if (currentMode === 'work') { totalSec = settings.work * 60; timeLeft = totalSec; }
  } else if (type === 'short') {
    settings.short = Math.max(1, Math.min(30, settings.short + delta));
    document.getElementById('cfgShort').innerHTML = settings.short;
    if (currentMode === 'shortBreak') { totalSec = settings.short * 60; timeLeft = totalSec; }
  } else {
    settings.long = Math.max(1, Math.min(60, settings.long + delta));
    document.getElementById('cfgLong').innerHTML = settings.long;
    if (currentMode === 'longBreak') { totalSec = settings.long * 60; timeLeft = totalSec; }
  }
  render();
}

// ── sound ─────────────────────────────────────────────────────────────────────
function playSound() {
  try {
    var sh = new ActiveXObject('WScript.Shell');
    sh.Run(
      'powershell -WindowStyle Hidden -Command ' +
      '"[console]::beep(880,150);' +
      'Start-Sleep -Milliseconds 100;' +
      '[console]::beep(1100,150);' +
      'Start-Sleep -Milliseconds 100;' +
      '[console]::beep(1320,350)"',
      0, false
    );
  } catch (e) {}
}

// ── init ──────────────────────────────────────────────────────────────────────
window.onload = function () {
  var W = 420, H = 590;
  window.resizeTo(W, H);
  window.moveTo(
    Math.round((screen.availWidth  - W) / 2),
    Math.round((screen.availHeight - H) / 2)
  );
  renderLang();
  renderDots();
};
</script>
</body>
</html>
